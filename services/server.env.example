# Server 端環境變數（複製為 .env，填入實際路徑）

# ── 路徑設定 ──────────────────────────────────────────────
CADHLLM_DRIVE_ROOT=/data/cadhllm          # Bridge JSON / 輸出根目錄
CADHLLM_LOCAL_STATE=/data/cadhllm/state   # Job bridge JSON 存放
CADHLLM_DB=/data/cadhllm/jobs.db          # SQLite JobQueue

# ── Phase I 模型設定 ───────────────────────────────────────
CADHLLM_ADAPTER_PATH=/data/cadhllm/saved_model   # rclone 同步後的 adapter
CADHLLM_BASE_MODEL=unsloth/mistral-7b-instruct-v0.3-bnb-4bit

# ── Phase VI VLM 設定 ──────────────────────────────────────
VLM_PROVIDER=local_llava                  # mock / local_llava / openai / grok
LLAVA_MODEL_PATH=/data/models/llava-1.5-7b-hf

# ── Gateway 設定 ───────────────────────────────────────────
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8000
