    "decisions": [
      {
        "step": "enclosure_partition",
        "principle": "殼體關係分流",
        "description": "依 enclosure_relation 分流 4 元件：pack(internal+breadboard)=2, panel=1, external=1, embedded=0。Pack 元件參與殼內 packing，panel 元件分配殼面，external/embedded 僅作走線 endpoint。",
        "formula": "bucket = ComponentSpec.enclosure_relation",
        "6e_stage": "engineer"
      },
      {
        "step": "gravity_sort",
        "principle": "重心穩定",
        "description": "依重量排序 3 個元件（總重 30g）。最重：Arduino-Uno (25g)，優先放置於底部。",
        "formula": "placement_priority = sorted(components, key=weight_g, desc)",
        "6e_stage": "engineer"
      },
      {
        "step": "thermal_classify",
        "principle": "熱源隔離",
        "description": "功耗 > 500mW 的熱源：MP3-Module(1000mW)。需與 0 個感測器保持距離，避免溫度影響量測精度。",
        "formula": "hot_threshold = 500 mW",
        "6e_stage": "engineer"
      },
      {
        "step": "zone_assign",
        "principle": "功能分區",
        "description": "依角色分區：Arduino-Uno→center; MP3-Module→bottom-edge; Button→center。Brain 居中便於走線輻射，感測器靠外壁便於開窗，熱源置底利用自然對流散熱。",
        "formula": "zone = f(role, is_hot)",
        "6e_stage": "engineer"
      },
      {
        "step": "shelf_pack",
        "principle": "空間最佳化",
        "description": "First-Fit Decreasing shelf packing：2 元件排入 114x85mm 空間，面積利用率 42%。元件間距 3mm 確保組裝空間與走線通道。",
        "formula": "utilization = 4087 / 9719 = 42%",
        "6e_stage": "engineer"
      },
      {
        "step": "collision_check",
        "principle": "干涉防護（PV2）",
        "description": "無碰撞：2 個元件 3D AABB 無重疊 ✓",
        "formula": "",
        "6e_stage": "engineer"
      },
      {
        "step": "cog_check",
        "principle": "重心穩定（PV4）",
        "description": "重心 (40.5, 26.8) 位於底座中央 2/3 區域內 （中心 56.9, 42.7）✓",
        "formula": "CoG ∈ [L/6, 5L/6] × [W/6, 5W/6]",
        "6e_stage": "engineer"
      },
      {
        "step": "panel_layout",
        "principle": "面板元件分配",
        "description": "1 個 panel 元件分配至殼面：Button→top@u=3。 各面有效寬度足夠容納。",
        "formula": "face = majority_vote(port.side); u = sum(L+clearance) per face",
        "6e_stage": "engineer"
      },
      {
        "step": "port_orient",
        "principle": "介面可達性",
        "description": "Port 朝向最近外壁：Arduino-Uno USB→side-front; MP3-Module USB→side-front。USB/電源口朝外便於插拔，感測器朝上或朝外便於偵測。",
        "formula": "face_out = argmin(distance_to_wall)",
        "6e_stage": "engineer"
      },
      {
        "step": "wire_route",
        "principle": "多層 3D 走線（pin-to-pin + riser + layer separation）",
        "description": "3D A* 完成 2 條走線（2 條 pin-to-pin），分佈於 2 層 Z 平面，總長度 160mm。各訊號類型佔獨立 Z 層避免交叉；同層走線互為障礙物避免重疊。",
        "formula": "path = A*(pin_pos, obstacles ∪ same_layer_wires); z = f(signal_type)",
        "6e_stage": "explain"
      },
      {
        "step": "thermal_validate",
        "principle": "散熱設計",
        "description": "總熱功率 1250mW，Tier=MID。密閉殼估算溫升 dT~6.5°C。500–1500mW，建議增加被動通風開口。 通風位置 1 處（總面積 4464mm²，基於自然對流 h=7.0 W/m²K、容許溫升 40.0°C）。",
        "formula": "A_vent = P / (h·ΔT_max) = 1.25W / (7.0×40.0) = 4464 mm²",
        "6e_stage": "explain"
      }
